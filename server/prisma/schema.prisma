// ============================================
// Phase 1.2: 电子证书管理 (Certificate Manager)
// ============================================

model CertificateTemplate {
  id             String   @id @default(uuid())
  name           String
  code           String   @unique
  certificateType String @default("AAC-038")
  description    String?
  bodyTemplate   String
  headerTemplate String?
  footerTemplate String?
  isActive       Boolean  @default(true)
  isDefault      Boolean  @default(false)
  version        Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?

  certificates Certificate[]

  @@index([certificateType, isActive, isDefault])
  @@map("certificate_templates")
}

model Certificate {
  id                String   @id @default(uuid())
  certificateNumber String   @unique
  templateId        String?

  // 关联对象
  inventoryId       String?
  inventoryDetailId String?
  orderId           String?
  supplierId        String?
  quotationId       String?

  // 航材信息
  partNumber        String
  serialNumber      String?
  description       String?
  quantity          Int?
  conditionCode     String?
  certificateType   String   @default("AAC-038")

  // 签发信息
  issueDate         DateTime @default(now())
  expiryDate        DateTime?
  issuedBy          String
  issuedById        String
  issuerCompany     String?
  issuerAddress     String?
  issuerCertNo      String?

  // 状态与验证
  status            String   @default("ISSUED")
  qrCodeData        String?
  verificationUrl   String?
  fileUrl           String?
  fileHash          String?

  // 追溯链
  traceHistory      String   @default("[]")
  parentCertificateId String?

  // 合规字段
  countryOfOrigin   String?
  manufactureDate   DateTime?
  batchNumber       String?
  ataChapter        String?
  aircraftModel     String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  template   CertificateTemplate? @relation(fields: [templateId], references: [id])
  inventory  Inventory?           @relation(fields: [inventoryId], references: [id])
  inventoryDetail InventoryDetail? @relation(fields: [inventoryDetailId], references: [id])
  order      Order?               @relation(fields: [orderId], references: [id])
  supplier   Supplier?            @relation(fields: [supplierId], references: [id])
  quotation  Quotation?           @relation(fields: [quotationId], references: [id])

  @@index([partNumber, status])
  @@index([certificateType, status])
  @@index([expiryDate, status])
  @@index([inventoryId])
  @@index([inventoryDetailId])
  @@index([orderId])
  @@map("certificates")
}

// ============================================
// Phase 1.3: 工作流引擎 (Workflow Engine)
// ============================================

model WorkflowDefinition {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  entityType  String   // RFQ / QUOTATION / ORDER / CERTIFICATE / SUPPLIER
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps    WorkflowStep[]
  instances WorkflowInstance[]

  @@index([entityType, isActive])
  @@map("workflow_definitions")
}

model WorkflowStep {
  id                String   @id @default(uuid())
  workflowId        String
  name              String
  stepOrder         Int
  stepType          String   @default("APPROVAL") // APPROVAL / NOTIFICATION / CONDITION / AUTOMATION
  approverRole      String?  // ADMIN / MANAGER / SALES / QUALITY / FINANCE
  approverUserId    String?  // 指定具体用户
  approverDepartment String? // 指定部门
  agentId           String?  // AI Agent 审批人
  isParallel        Boolean  @default(false)
  parallelMinCount  Int?     // 并行审批最少通过人数
  timeoutHours      Int      @default(24)
  timeoutAction     String   @default("ESCALATE") // ESCALATE / AUTO_APPROVE / AUTO_REJECT
  conditionExpression String? // 条件表达式 (如: amount > 10000)
  autoAction        String?  // 自动化动作
  notificationTemplate String? // 通知模板

  createdAt DateTime @default(now())

  workflow WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  instanceSteps WorkflowInstanceStep[]

  @@index([workflowId, stepOrder])
  @@map("workflow_steps")
}

model WorkflowInstance {
  id           String   @id @default(uuid())
  definitionId String
  entityType   String
  entityId     String
  status       String   @default("RUNNING") // RUNNING / COMPLETED / REJECTED / CANCELLED / TIMEOUT
  currentStepId String?
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  startedBy    String
  context      String   @default("{}") // JSON: 工作流上下文数据

  definition WorkflowDefinition @relation(fields: [definitionId], references: [id])
  steps      WorkflowInstanceStep[]
  actions    WorkflowAction[]

  @@index([entityType, entityId])
  @@index([status, startedAt])
  @@map("workflow_instances")
}

model WorkflowInstanceStep {
  id           String   @id @default(uuid())
  instanceId   String
  stepId       String
  stepOrder    Int
  status       String   @default("PENDING") // PENDING / IN_PROGRESS / APPROVED / REJECTED / SKIPPED / TIMEOUT
  assignedTo   String?  // 分配给的用户ID
  assignedRole String?  // 分配的角色
  startedAt    DateTime?
  completedAt  DateTime?
  dueAt        DateTime?
  result       String?  // 审批结果备注

  instance WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  step       WorkflowStep     @relation(fields: [stepId], references: [id])
  actions    WorkflowAction[]

  @@index([instanceId, stepOrder])
  @@index([assignedTo, status])
  @@map("workflow_instance_steps")
}

model WorkflowAction {
  id           String   @id @default(uuid())
  instanceId   String
  instanceStepId String?
  actionType   String   // APPROVE / REJECT / TRANSFER / COMMENT / ESCALATE / AUTO_ACTION
  actorId      String
  actorRole    String?
  actorName    String?
  comment      String?
  payload      String   @default("{}") // JSON: 附加数据
  createdAt    DateTime @default(now())

  instance     WorkflowInstance     @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  instanceStep WorkflowInstanceStep? @relation(fields: [instanceStepId], references: [id])

  @@index([instanceId, createdAt])
  @@index([actorId, createdAt])
  @@map("workflow_actions")
}

// ============================================
// Phase 1.4: 操作日志审计 (Audit Log)
// ============================================

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?
  userName     String?
  userRole     String?
  action       String   // CREATE / UPDATE / DELETE / VIEW / LOGIN / LOGOUT / EXPORT / APPROVE / REJECT
  resourceType String   // RFQ / QUOTATION / ORDER / INVENTORY / CUSTOMER / SUPPLIER / CERTIFICATE / SETTINGS
  resourceId   String?
  resourceName String?  // 资源名称（如件号、客户名）
  changes      String?  // JSON: { field: { before, after } }
  details      String?  // 操作详情描述
  ipAddress    String?
  userAgent    String?
  sessionId    String?
  status       String   @default("SUCCESS") // SUCCESS / FAILURE
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([resourceType, resourceId])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}


// ============================================
// Phase 2.3: 拍卖模块 (Auction Module)
// ============================================

model Auction {
  id              String   @id @default(uuid())
  auctionNumber   String   @unique
  title           String
  description     String?
  type            String   @default("SALES") // SALES / REVERSE / SEALED
  status          String   @default("DRAFT") // DRAFT / ACTIVE / CLOSED / CANCELLED

  // 拍卖标的
  partNumber      String
  partDescription String?
  quantity        Int
  conditionCode   String?
  certificateType String?

  // 价格设置
  startingPrice   Float?
  reservePrice    Float?   // 保留价（低于此价不成交）
  buyNowPrice     Float?   // 一口价
  currency        String   @default("USD")

  // 时间设置
  startAt         DateTime
  endAt           DateTime
  autoExtend      Boolean  @default(true) // 截止前5分钟出价自动延长
  extendMinutes   Int      @default(5)

  // 参与方
  sellerId        String?  // 销售拍卖：卖家
  buyerId         String?  // 反向拍卖：买家
  invitedSupplierIds String? // JSON 数组，邀请的供应商ID

  // 结果
  winnerBidId     String?
  finalPrice      Float?
  closedAt        DateTime?
  closedReason    String?  // EXPIRED / SOLD / CANCELLED / NO_BIDS

  // 关联
  inventoryId     String?
  rfqId           String?

  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bids            AuctionBid[]

  @@index([status, endAt])
  @@index([partNumber, status])
  @@map("auctions")
}

model AuctionBid {
  id          String   @id @default(uuid())
  auctionId   String
  bidderId    String   // 用户ID或供应商ID
  bidderType  String   @default("USER") // USER / SUPPLIER
  bidderName  String
  amount      Float
  currency    String   @default("USD")
  quantity    Int      @default(1)
  isAutoBid   Boolean  @default(false) // 自动出价
  maxAutoBid  Float?   // 自动出价上限
  bidTime     DateTime @default(now())
  isWinning   Boolean  @default(false)
  isSealed    Boolean  @default(false) // 密封投标
  notes       String?

  auction     Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@index([auctionId, bidTime])
  @@index([auctionId, amount])
  @@map("auction_bids")
}


// ============================================
// Phase 2.4: 寄售管理 (Consignment Module)
// ============================================

model Consignment {
  id              String   @id @default(uuid())
  agreementNumber String   @unique
  title           String
  description     String?
  status          String   @default("ACTIVE") // ACTIVE / EXPIRED / TERMINATED / SETTLING

  // 参与方
  supplierId      String
  customerId      String?
  supplierName    String
  customerName    String?

  // 寄售标的
  partNumber      String
  partDescription String?
  quantity        Int      @default(0)
  unitCost        Float    @default(0)
  currency        String   @default("USD")
  conditionCode   String?

  // 协议条款
  agreementDate   DateTime @default(now())
  startDate       DateTime @default(now())
  endDate         DateTime
  minStockLevel   Int      @default(0) // 最低库存要求
  reorderPoint    Int      @default(0) // 再订货点
  reorderQuantity Int      @default(0) // 建议订货量
  settlementTerms String   @default("MONTHLY") // MONTHLY / WEEKLY / PER_CONSUMPTION / QUARTERLY
  paymentTerms    String?  // 结算账期
  commissionRate  Float?   // 佣金比例 %

  // 库存跟踪
  initialQuantity Int      @default(0)
  consumedQuantity Int    @default(0)
  returnedQuantity Int    @default(0)
  currentQuantity Int     @default(0)

  // 预警
  lastSettlementDate DateTime?
  nextSettlementDate DateTime?
  isOverdue       Boolean  @default(false)
  daysUntilExpiry Int?

  // 关联
  inventoryId     String?
  orderIds        String?  // JSON 数组

  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, endDate])
  @@index([supplierId, status])
  @@index([partNumber, status])
  @@map("consignments")
}


// ============================================
// Phase 3.1: API Key 管理 (API Platform)
// ============================================

model ApiKey {
  id          String   @id @default(uuid())
  name        String
  keyHash     String   @unique
  keyPrefix   String   // 用于显示的前缀，如 "ak_live_abc..."
  scopes      String   @default("[\"read\"]") // JSON 数组: read, write, admin
  rateLimit   Int      @default(1000) // 每小时请求数
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([keyHash])
  @@index([isActive])
  @@map("api_keys")
}

// ============================================
// Phase 3.4: 区块链证书存证 (Blockchain)
// ============================================

model BlockchainRecord {
  id              String   @id @default(uuid())
  index           Int      @unique
  timestamp       DateTime
  certificateId   String   @unique
  certificateHash String
  previousHash    String
  hash            String
  nonce           Int

  @@index([certificateId])
  @@index([index])
  @@map("blockchain_records")
}

// ===== Phase 6: 统一通知中心（IM / SMS 渠道绑定）=====
model UserChannelBinding {
  id        String   @id @default(uuid())
  userId    String
  channel   String   // WECHAT / DINGTALK / LARK / SMS / SLACK / TEAMS
  config    Json     // { openId, unionId, phone, corpId, deptId }
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
  @@map("user_channel_bindings")
}

model NotificationTemplate {
  id       String @id @default(uuid())
  event    String // RFQ_CREATED / QUOTE_APPROVED / AOG_ALERT / APPROVAL_PENDING
  channel  String // EMAIL / WECHAT / DINGTALK / LARK / SMS / SYSTEM
  subject  String
  body     String // 支持 {{partNumber}} {{customerName}} 变量
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([event, channel])
  @@map("notification_templates")
}

// ===== Phase 7: PWA Web Push 订阅 =====
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @unique
  endpoint  String
  p256dh    String
  auth      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}
