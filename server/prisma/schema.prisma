model AgentRuntimeConfirmation {
  id             String   @id
  taskId          String   @unique
  stepId          String
  type            String
  title           String
  titleZh         String?
  titleEn         String?
  description     String
  descriptionZh   String?
  descriptionEn   String?
  data            String   @default("{}")
  options         String   @default("[]")
  selectedOption  String?
  confirmedAt     DateTime?
  confirmedBy     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  task            AgentRuntimeTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("agent_runtime_confirmations")
