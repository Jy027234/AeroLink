{
  "name": "aerolink-server",
  "version": "1.0.0",
  "description": "AeroLink Aviation Parts Management System - Backend API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "prisma generate && prisma db push && node --import tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:preflight:order-uniqueness": "node --import tsx src/scripts/checkOrderUniqueness.ts",
    "db:check-active-admin": "node --import tsx src/scripts/checkActiveAdmin.ts",
    "db:check:inventory-reconciliation": "node --import tsx src/scripts/checkInventoryReconciliation.ts",
    "db:rotate-encryption-key": "node --import tsx src/scripts/rotateEncryptionKey.ts",
    "db:seed": "node --import tsx src/seed.ts",
    "db:bootstrap-admin": "node --import tsx src/scripts/bootstrapAdmin.ts",
    "db:prepare:legacy-sqlite": "node --import tsx src/scripts/prepareLegacySqlite.ts",
    "db:import:sqlite-to-postgres": "node --import tsx src/scripts/importSqliteToPostgres.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^8.5.1",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "imap-simple": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "mailparser": "^3.9.8",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.3",
    "openai": "^6.37.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "puppeteer": "^24.43.0",
    "sanitize-html": "^2.17.6",
    "socket.io": "^4.7.4",
    "zod": "^3.23.8"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "form-data": "^4.0.6",
    "utf7": {
      "semver": "5.7.2"
    },
    "vite": "^8.1.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^8.0.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
