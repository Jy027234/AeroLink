PUBLIC_ORIGIN=https://aerolink.example.com
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
# PostgreSQL profile 必填；SQLite 兼容 profile 可忽略
DB_PASSWORD=replace-with-a-strong-database-password
# PostgreSQL profile defaults to migrate deploy. Set true only after baseline resolution in staging/backup.
SCHEMA_MIGRATION_MODE=migrate
MIGRATION_BASELINE_CONFIRMED=false
ALLOW_DB_PUSH=false
# SQLite compatibility profile overrides the PostgreSQL migration knobs above.
SQLITE_SCHEMA_MIGRATION_MODE=push
SQLITE_ALLOW_DB_PUSH=true
# 生产环境默认关闭演示数据；仅在隔离演示环境显式设为 true
SEED_DEMO_DATA=false
# 仅在隔离演示环境与 SEED_DEMO_DATA=true 一起设置，不要提交真实生产口令
DEMO_SEED_PASSWORD=
ALLOW_PRODUCTION_DEMO_SEED=false
# Experimental product areas are disabled by default. Enable only in an
# isolated environment with a documented data source and owner.
FEATURE_PRICING_BI=false
FEATURE_AGENT_DEMO=false
# Fresh production databases must be bootstrapped with an activated privileged user.
REQUIRE_ACTIVE_ADMIN=true
# Secure refresh cookies require a public HTTPS origin (TLS profile or upstream proxy).
REQUIRE_SECURE_ORIGIN=true
# External trace export is disabled by default. If enabled, the deployment record
# must include both collector retention values and the collector-side deletion policy.
TRACE_EXPORTER_URL=
OBSERVABILITY_METRICS_RETENTION_DAYS=
OBSERVABILITY_TRACE_RETENTION_HOURS=
