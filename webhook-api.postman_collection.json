{
  "info": {
    "name": "航材交易平台 Webhook API",
    "description": "完整的 Webhook 端点管理、订阅、投递日志和重试接口集合",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "your_jwt_bearer_token_here",
      "type": "string"
    },
    {
      "key": "webhook_secret",
      "value": "your_webhook_secret_here",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Webhook 端点管理",
      "item": [
        {
          "name": "创建 Webhook 端点",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://example.com/webhooks/receiver\",\n  \"authMethod\": \"HMAC\",\n  \"secret\": \"{{webhook_secret}}\",\n  \"headers\": {\n    \"X-Custom-Header\": \"custom-value\"\n  },\n  \"maxRetries\": 5,\n  \"timeoutSeconds\": 30\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/endpoints",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "endpoints"]
            }
          },
          "response": []
        },
        {
          "name": "查看所有 Webhook 端点",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/webhooks/endpoints",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "endpoints"]
            }
          },
          "response": []
        },
        {
          "name": "更新 Webhook 端点",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://example.com/webhooks/receiver-v2\",\n  \"status\": \"ACTIVE\",\n  \"maxRetries\": 10\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/endpoints/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "endpoints", ":id"]
            }
          },
          "response": []
        },
        {
          "name": "删除 Webhook 端点",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/webhooks/endpoints/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "endpoints", ":id"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Webhook 订阅管理",
      "item": [
        {
          "name": "创建事件订阅（RFQ 事件）",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"endpointId\": \"endpoint_uuid_here\",\n  \"eventTypes\": [\"rfq.created\", \"rfq.status.changed\"],\n  \"filters\": {\n    \"urgency\": [\"AOG\"],\n    \"status\": [\"PENDING\", \"QUOTED\"]\n  },\n  \"active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/subscriptions",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "subscriptions"]
            }
          },
          "response": []
        },
        {
          "name": "创建事件订阅（报价事件）",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"endpointId\": \"endpoint_uuid_here\",\n  \"eventTypes\": [\"quotation.created\", \"quotation.submitted\", \"quotation.approved\"],\n  \"filters\": {\n    \"status\": [\"APPROVED\"]\n  },\n  \"active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/subscriptions",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "subscriptions"]
            }
          },
          "response": []
        },
        {
          "name": "创建事件订阅（订单事件）",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"endpointId\": \"endpoint_uuid_here\",\n  \"eventTypes\": [\"order.created\", \"order.status.changed\"],\n  \"filters\": {\n    \"status\": [\"CONFIRMED\", \"SHIPPED\"]\n  },\n  \"active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/subscriptions",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "subscriptions"]
            }
          },
          "response": []
        },
        {
          "name": "创建事件订阅（Agent 任务事件）",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"endpointId\": \"endpoint_uuid_here\",\n  \"eventTypes\": [\"agent.task.completed\", \"agent.task.failed\"],\n  \"filters\": {\n    \"taskType\": [\"PRICE_ANALYSIS\", \"COMPETITOR_ANALYSIS\"]\n  },\n  \"active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/subscriptions",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "subscriptions"]
            }
          },
          "response": []
        },
        {
          "name": "查看所有订阅",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/webhooks/subscriptions",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "subscriptions"]
            }
          },
          "response": []
        },
        {
          "name": "更新订阅",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventTypes\": [\"rfq.created\"],\n  \"filters\": {\n    \"urgency\": [\"AOG\", \"STOCK\"]\n  },\n  \"active\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/subscriptions/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "subscriptions", ":id"]
            }
          },
          "response": []
        },
        {
          "name": "删除订阅",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/webhooks/subscriptions/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "subscriptions", ":id"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Webhook 测试与投递",
      "item": [
        {
          "name": "测试 Webhook 端点连接",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"endpointId\": \"endpoint_uuid_here\",\n  \"eventType\": \"test.delivery\",\n  \"payload\": {\n    \"message\": \"This is a test webhook delivery\",\n    \"timestamp\": \"2026-05-12T10:00:00Z\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/test",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "test"]
            }
          },
          "response": []
        },
        {
          "name": "查看投递日志（所有）",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/webhooks/deliveries?limit=50&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "deliveries"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "查看投递日志（按端点过滤）",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/webhooks/deliveries?endpointId=endpoint_uuid_here&status=FAILED",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "deliveries"],
              "query": [
                {
                  "key": "endpointId",
                  "value": "endpoint_uuid_here"
                },
                {
                  "key": "status",
                  "value": "FAILED"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "查看单条投递详情",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/webhooks/deliveries/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "deliveries", ":id"]
            }
          },
          "response": []
        },
        {
          "name": "手动重试失败的投递",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/webhooks/deliveries/:id/retry",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "deliveries", ":id", "retry"]
            }
          },
          "response": []
        }
      ]
    },
