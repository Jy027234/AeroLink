{
  "name": "my-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "audit:deps": "npm audit --registry=https://registry.npmjs.org && npm --prefix server audit --registry=https://registry.npmjs.org",
    "api:scaffold": "node scripts/openapi/generate-scaffold.mjs --write",
    "api:scaffold:reset": "node scripts/openapi/generate-scaffold.mjs --write --force",
    "api:lint": "redocly lint --config redocly.yaml contracts/openapi/openapi.json",
    "api:generate": "openapi-typescript contracts/openapi/openapi.json -o src/api/generated/openapi.d.ts",
    "api:check:generated": "node scripts/openapi/check-generated.mjs",
    "api:check": "node scripts/openapi/check-route-coverage.mjs && npm run api:lint && npm run api:check:generated",
    "api:check:strict": "node scripts/openapi/check-route-coverage.mjs --strict && npm run api:lint && npm run api:check:generated",
    "features:check": "node scripts/check-feature-boundaries.mjs",
    "modules:check": "node scripts/check-server-module-boundaries.mjs",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:p2-responsive-a11y": "playwright test e2e/p2-responsive-a11y.spec.ts --project=chromium",
    "test:e2e:p2-settings-url": "playwright test e2e/p2-settings-url.spec.ts --project=chromium",
    "test:e2e:p2-keyboard-focus": "playwright test e2e/p2-keyboard-focus.spec.ts --project=chromium",
    "p2:runtime-baseline": "node scripts/p2-runtime-baseline.mjs",
    "observability:verify-retention-evidence": "node scripts/verify-observability-retention-evidence.mjs",
    "a11y:verify-manual-evidence": "node scripts/verify-p2-09-manual-evidence.mjs",
    "test:e2e:navigation-regression": "playwright test e2e/navigation.spec.ts --project=chromium",
    "test:e2e:quotation-contract-regression": "playwright test e2e/quotation-contract-flow.spec.ts e2e/contract-template-management.spec.ts --project=chromium"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "js-yaml": "4.2.0",
    "undici": "7.28.0",
    "ws": "8.21.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.562.0",
    "next-themes": "^0.4.6",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.70.0",
    "react-resizable-panels": "^4.2.2",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@redocly/cli": "^2.39.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "happy-dom": "^20.9.0",
    "js-yaml": "4.2.0",
    "jsdom": "^29.1.1",
    "kimi-plugin-inspect-react": "^1.0.3",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.6",
    "pptxgenjs": "^4.0.1",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.3.6",
    "vitest": "^4.1.5"
  }
}
